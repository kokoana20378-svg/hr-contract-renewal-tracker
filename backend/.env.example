# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hr_contracts

# Redis
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# JWT
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=24h

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Multi-Tenant
MULTI_TENANT_ENABLED=false
