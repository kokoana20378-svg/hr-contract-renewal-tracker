generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  config    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]
  settings  Setting[]
}

model Employee {
  id        Int      @id @default(autoincrement())
  name      String
  hireDate  DateTime
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([hireDate])
}

model Setting {
  key       String
  value     String
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@id([key])
  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  userId    String?
  tenantId  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
  @@index([action, entity])
}
